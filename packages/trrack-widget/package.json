{
  "name": "trrack-controls",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild js/controls.tsx --bundle --format=esm --minify --outdir=src/trrack_widget/static",
    "dev": "esbuild js/controls.tsx --bundle --format=esm --sourcemap=inline --watch --outdir=src/trrack_widget/static",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint js",
    "format": "oxfmt --write js",
    "format:check": "oxfmt --check js"
  },
  "dependencies": {
    "@anywidget/react": "^0.2.2",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@anywidget/types": "^0.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.24.0",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
